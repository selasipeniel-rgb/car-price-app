   "source": [
    "# check price distribution before cleaning\n",
    "print(\"Before outlier removal:\")\n",
    "print(car_df['price'].describe())\n",
    "print(f\"\\nTop 10 prices:\\n{car_df['price'].sort_values(ascending=False).head(10).values}\")\n",
    "\n",
    "# remove top and bottom 1% price outliers\n",
    "low  = car_df['price'].quantile(0.01)\n",
    "high = car_df['price'].quantile(0.99)\n",
    "car_df = car_df[(car_df['price'] >= low) & (car_df['price'] <= high)]\n",
    "\n",
    "print(f\"\\nAfter outlier removal: {len(car_df)} rows\")\n",
    "print(car_df['price'].describe())"
   ]
  },
  {
