    "]\n",
    "\n",
    "for ax, (col, label) in zip(axes.flatten(), plots):\n",
    "    ax.scatter(car_df[col], car_df['price'], alpha=0.3, s=5)\n",
    "    ax.set_xlabel(label)\n",
